{
  "info": {
    "name": "User Service API",
    "description": "Postman collection for User Service - E-commerce Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3002/api/v1",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          }
        },
        {
          "name": "Create Profile",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1234567890\",\n  \"dateOfBirth\": \"1990-01-15\",\n  \"gender\": \"male\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\",\n  \"bio\": \"Software developer\"\n}"
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1987654321\",\n  \"bio\": \"Updated bio\"\n}"
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          }
        }
      ]
    },
