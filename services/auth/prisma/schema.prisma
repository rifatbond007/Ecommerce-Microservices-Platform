generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid()) @db.Uuid
  email                String     @unique @map("email") @db.VarChar(255)
  passwordHash         String     @map("password_hash") @db.VarChar(255)
  username             String     @unique @map("username") @db.VarChar(100)
  firstName            String     @map("first_name") @db.VarChar(100)
  lastName             String     @map("last_name") @db.VarChar(100)
  phone                String?    @map("phone") @db.VarChar(20)
  avatarUrl            String?    @map("avatar_url") @db.VarChar(500)
  isActive             Boolean    @default(true) @map("is_active")
  isVerified           Boolean    @default(false) @map("is_verified")
  verificationToken    String?    @map("verification_token") @db.VarChar(255)
  resetPasswordToken   String?    @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpires DateTime?  @map("reset_password_expires")
  failedLoginAttempts  Int        @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime?  @map("locked_until")
  lastLoginAt          DateTime?  @map("last_login_at")
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions             Session[]
  roles                UserRole[]

  @@index([email], map: "idx_users_email")
  @@index([username], map: "idx_users_username")
  @@index([verificationToken], map: "idx_users_verification_token")
  @@map("users")
}

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique @map("name") @db.VarChar(50)
  description String?    @map("description")
  permissions Json       @default("[]") @map("permissions")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  users       UserRole[]

  @@index([name], map: "idx_roles_name")
  @@map("roles")
}

model UserRole {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], name: "idx_user_roles_unique")
  @@index([userId], map: "idx_user_roles_user_id")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@map("user_roles")
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  tokenHash      String   @unique @map("token_hash") @db.VarChar(255)
  deviceInfo     Json?    @map("device_info")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent")
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActivityAt DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@index([tokenHash], map: "idx_sessions_token_hash")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("sessions")
}

model LoginAttempt {
  id          Int      @id @default(autoincrement())
  email       String   @map("email") @db.VarChar(255)
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  success     Boolean
  attemptTime DateTime @default(now()) @map("attempt_time") @db.Timestamptz(6)
  userAgent   String?  @map("user_agent")

  @@index([email], map: "idx_login_attempts_email")
  @@index([ipAddress], map: "idx_login_attempts_ip_address")
  @@index([attemptTime], map: "idx_login_attempts_attempt_time")
  @@map("login_attempts")
}
