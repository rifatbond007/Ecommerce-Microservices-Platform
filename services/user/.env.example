# Service Configuration
PORT=3002
SERVICE_NAME=user-service
NODE_ENV=development

# Database
DATABASE_URL=postgresql://ecommerce:ecommerce_dev_password@localhost:5432/ecommerce?schema=user_service

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://ecommerce:ecommerce_dev_password@localhost:5672

# Auth Service (for internal API calls)
AUTH_SERVICE_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info


# Admin Configuration
ADMIN_EMAIL=admin email address
