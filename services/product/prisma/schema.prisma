generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  name         String    @unique @map("name") @db.VarChar(100)
  slug         String    @unique @map("slug") @db.VarChar(100)
  description  String?   @map("description")
  imageUrl     String?   @map("image_url") @db.VarChar(500)
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent       Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[] @relation("CategoryHierarchy")
  products     Product[]

  @@index([slug], map: "idx_categories_slug")
  @@index([parentId], map: "idx_categories_parent_id")
  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @map("name") @db.VarChar(100)
  slug        String    @unique @map("slug") @db.VarChar(100)
  description String?   @map("description")
  logoUrl     String?   @map("logo_url") @db.VarChar(500)
  website     String?   @map("website") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products    Product[]

  @@index([slug], map: "idx_brands_slug")
  @@map("brands")
}

model Product {
  id               String            @id @default(uuid()) @db.Uuid
  sku              String            @unique @map("sku") @db.VarChar(50)
  name             String            @map("name") @db.VarChar(255)
  slug             String            @unique @map("slug") @db.VarChar(255)
  description      String?           @map("description")
  categoryId       String            @map("category_id") @db.Uuid
  brandId          String?           @map("brand_id") @db.Uuid
  basePrice        Decimal           @db.Decimal(12, 2) @map("base_price")
  compareAtPrice   Decimal?          @map("compare_at_price") @db.Decimal(12, 2)
  costPerItem      Decimal?          @map("cost_per_item") @db.Decimal(12, 2)
  weight           Decimal?          @map("weight") @db.Decimal(10, 2)
  requiresShipping Boolean           @default(true) @map("requires_shipping")
  isTaxable        Boolean           @default(true) @map("is_taxable")
  taxRate          Decimal?          @map("tax_rate") @db.Decimal(5, 4)
  tags             Json              @default("[]") @map("tags")
  images           Json              @default("[]") @map("images")
  videoUrl         String?           @map("video_url") @db.VarChar(500)
  metaTitle        String?           @map("meta_title") @db.VarChar(70)
  metaDescription  String?           @map("meta_description") @db.VarChar(160)
  totalSold        Int               @default(0) @map("total_sold")
  totalRevenue     Decimal           @default(0) @map("total_revenue") @db.Decimal(14, 2)
  averageRating    Decimal           @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount      Int               @default(0) @map("review_count")
  isActive         Boolean           @default(true) @map("is_active")
  isFeatured       Boolean           @default(false) @map("is_featured")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  category         Category          @relation(fields: [categoryId], references: [id])
  brand            Brand?            @relation(fields: [brandId], references: [id])
  variants         ProductVariant[]
  inventories      Inventory[]

  @@index([sku], map: "idx_products_sku")
  @@index([slug], map: "idx_products_slug")
  @@index([categoryId], map: "idx_products_category_id")
  @@index([brandId], map: "idx_products_brand_id")
  @@index([isActive], map: "idx_products_is_active")
  @@index([isFeatured], map: "idx_products_is_featured")
  @@index([basePrice], map: "idx_products_base_price")
  @@map("products")
}

model ProductVariant {
  id                 String   @id @default(uuid()) @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  sku                String   @unique @map("sku") @db.VarChar(50)
  name               String   @map("name") @db.VarChar(255)
  price              Decimal  @map("price") @db.Decimal(12, 2)
  compareAtPrice     Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  costPerItem        Decimal? @map("cost_per_item") @db.Decimal(12, 2)
  inventoryQuantity  Int      @default(0) @map("inventory_quantity")
  inventoryPolicy   String   @default("deny") @map("inventory_policy") @db.VarChar(20)
  weight             Decimal? @map("weight") @db.Decimal(10, 2)
  barcode            String?  @map("barcode") @db.VarChar(50)
  options            Json     @default("{}") @map("options")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventories       Inventory[]

  @@index([sku], map: "idx_product_variants_sku")
  @@index([productId], map: "idx_product_variants_product_id")
  @@index([isActive], map: "idx_product_variants_is_active")
  @@map("product_variants")
}

model Inventory {
  id                String          @id @default(uuid()) @db.Uuid
  productId         String          @map("product_id") @db.Uuid
  variantId         String?         @map("variant_id") @db.Uuid
  warehouseId       String          @map("warehouse_id") @db.Uuid
  quantity          Int             @default(0) @map("quantity")
  reservedQuantity  Int             @default(0) @map("reserved_quantity")
  reorderPoint      Int             @default(10) @map("reorder_point")
  reorderQuantity   Int?            @map("reorder_quantity")
  lastRestockedAt   DateTime?       @map("last_restocked_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse       @relation(fields: [warehouseId], references: [id])

  @@unique([productId, variantId, warehouseId], map: "unique_inventory")
  @@index([productId], map: "idx_inventories_product_id")
  @@index([variantId], map: "idx_inventories_variant_id")
  @@index([warehouseId], map: "idx_inventories_warehouse_id")
  @@map("inventories")
}

model Warehouse {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique @map("name") @db.VarChar(100)
  code         String    @unique @map("code") @db.VarChar(20)
  addressLine1 String    @map("address_line1") @db.VarChar(255)
  addressLine2 String?   @map("address_line2") @db.VarChar(255)
  city         String    @map("city") @db.VarChar(100)
  state        String    @map("state") @db.VarChar(100)
  postalCode   String    @map("postal_code") @db.VarChar(20)
  country      String    @map("country") @db.VarChar(2)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  inventories  Inventory[]

  @@index([code], map: "idx_warehouses_code")
  @@map("warehouses")
}
